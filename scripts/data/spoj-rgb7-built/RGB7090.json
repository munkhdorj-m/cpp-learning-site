    "reference_cpp": "#include <iostream>\n\nusing namespace std;\n\nint main() {\n    ios::sync_with_stdio(false);\n    cin.tie(nullptr);\n\n    long long k;\n    cin >> k;\n\n    // Number of ways to put k indistinguishable items into 4 distinguishable boxes\n    // = C(k+4-1, 4-1) = C(k+3, 3)\n    // C(k+3, 3) = (k+3)*(k+2)*(k+1) / 6\n    long long ans = (k + 3) * (k + 2) * (k + 1) / 6;\n\n    cout << ans << '\\n';\n    return 0;\n}\n",
