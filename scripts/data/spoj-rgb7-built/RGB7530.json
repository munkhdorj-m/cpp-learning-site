  "data": {
    "slug": "array-rotation",
    "title_mn": "Массив эргүүлэлт",
    "title_en": "Array Rotation",
    "statement_mn": "Өгөгдсөн $n \\times m$ хэмжээст массивыг цагийн зүүний дагуу 90 градус эргүүл.",
    "statement_en": "Rotate the given $n \\times m$ matrix 90 degrees clockwise.",
    "input_format_mn": "Эхний мөрөнд массивын хэмжээс $n,m$ ($n,m \\le 50$) натурал тоонууд зайгаар тусгаарлагдан өгөгдөнө. Дараагийн $n$ мөрөнд $m$ бүхэл тоонууд нэг нэг зайгаар тусгаарлагдан өгөгдөнө.",
    "input_format_en": "The first line contains two integers $n$ and $m$ ($n, m \\le 50$), the dimensions of the matrix. The next $n$ lines each contain $m$ integers separated by spaces.",
    "output_format_mn": "Эргүүлсэн массивын мөр тус бүрийн тоонуудыг нэг нэг зайгаар тусгаарлан хэвлэ. Эхний мөрөнд эргүүлсэн массивын хэмжээс $m$, $n$-г хэвлэнэ.",
    "output_format_en": "Print the rotated matrix. The first line should contain the new dimensions $m$ and $n$. Then print $m$ lines, each containing $n$ integers separated by spaces.",
    "constraints_mn": "- $1 \\le n, m \\le 50$\n- Массивын элементүүд бүхэл тоо, утгын хязгаар тодорхойгүй (int багтана)",
    "constraints_en": "- $1 \\le n, m \\le 50$\n- Matrix elements are integers fitting in 32-bit signed integer",
    "difficulty": "easy",
    "tags": [
      "matrix",
      "rotation",
      "implementation"
    ],
    "time_limit_ms": 500,
    "memory_limit_kb": 16384,
    "xp_reward": 10,
    "reference_cpp": "#include <iostream>\n#include <vector>\n\nusing namespace std;\n\nint main() {\n    ios_base::sync_with_stdio(false);\n    cin.tie(nullptr);\n\n    int n, m;\n    cin >> n >> m;\n\n    vector<vector<int>> a(n, vector<int>(m));\n    for (int i = 0; i < n; ++i) {\n        for (int j = 0; j < m; ++j) {\n            cin >> a[i][j];\n        }\n    }\n\n    // Rotate 90 degrees clockwise: new[i][j] = old[n-1-j][i]\n    // But simpler: output with reversed row order of transposed matrix\n    // Transpose: rows become columns, then reverse each row\n    // Actually: output dimensions m x n\n    cout << m << ' ' << n << '\\n';\n    for (int j = 0; j < m; ++j) {\n        for (int i = n - 1; i >= 0; --i) {\n            cout << a[i][j];\n            if (i > 0) cout << ' ';\n        }\n        cout << '\\n';\n    }\n\n    return 0;\n}\n",
